{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "terra",
  "version": "0.1.0",
  "identifier": "dev.terra.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "terra",
        "width": 1280,
        "height": 800
      }
    ],
    "security": {
      "csp": null
    },
    "trayIcon": {
      "iconPath": "icons/icon.png",
      "iconAsTemplate": true,
      "tooltip": "terra"
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/ryu1-1uyr/terra/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDU2MzgyRUY0NkUwN0FENwpSV1RYZXVCRzc0SmpCVFNDa1o1WGtYVGV1c2JML3FjNkhGTHk2TXFmdE81QWVsd05JRTBaVzQ4UQo="
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
